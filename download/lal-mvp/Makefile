# Makefile for LAL MVP — builds the specialized and generic demos for x86_64 and arm64.
#
# Targets:
#   make x86        — build both demos for x86_64 (host)
#   make arm64      — cross-compile both demos for arm64 (requires aarch64-linux-gnu-gcc)
#   make verify     — run verification (specialized output matches Python reference)
#   make bench      — run compute-only benchmark
#   make clean      — remove build artifacts
#
# The specialized demo (demo.c) is generated by the LAL compiler from demo.lal.
# The generic demo (demo_generic.c) is hand-written for comparison.

CC_X86      ?= gcc
CC_ARM64    ?= aarch64-linux-gnu-gcc
CFLAGS      ?= -O3 -Wall -Wextra
LALC        ?= python3 ../../scripts/lal/lal.py

SRC_DIR     := src
BUILD_DIR   := build
LAL_SRC     := $(SRC_DIR)/demo.lal

.PHONY: all x86 arm64 verify bench clean

all: x86

# Generate demo.c from demo.lal (specialized version)
$(SRC_DIR)/demo.c: $(LAL_SRC)
	$(LALC) $(LAL_SRC) classify $(SRC_DIR)/demo.c

# x86_64 targets
x86: $(BUILD_DIR)/demo_x86_64 $(BUILD_DIR)/demo_generic_x86_64

$(BUILD_DIR)/demo_x86_64: $(SRC_DIR)/demo.c
	@mkdir -p $(BUILD_DIR)
	$(CC_X86) $(CFLAGS) -o $@ $<

$(BUILD_DIR)/demo_generic_x86_64: $(SRC_DIR)/demo_generic.c
	@mkdir -p $(BUILD_DIR)
	$(CC_X86) $(CFLAGS) -o $@ $<

# arm64 targets (cross-compile; can't run without qemu-aarch64-static)
arm64: $(BUILD_DIR)/demo_arm64 $(BUILD_DIR)/demo_generic_arm64

$(BUILD_DIR)/demo_arm64: $(SRC_DIR)/demo.c
	@mkdir -p $(BUILD_DIR)
	$(CC_ARM64) $(CFLAGS) -o $@ $<

$(BUILD_DIR)/demo_generic_arm64: $(SRC_DIR)/demo_generic.c
	@mkdir -p $(BUILD_DIR)
	$(CC_ARM64) $(CFLAGS) -o $@ $<

# Verify specialized matches Python reference
verify:
	python3 ../../scripts/lal/verify.py

# Compute-only benchmark
bench:
	python3 ../../scripts/lal/benchmark.py

clean:
	rm -rf $(BUILD_DIR) $(SRC_DIR)/demo.c
